# 编译期环境变量模板
#
# 用法：复制本文件，填入真实值
#   cp .dev.env.template .dev.env    # 本地调试（flutter run / run_simulator.sh）
#   cp .dev.env.template .prod.env   # 发布（release_*.sh），并把 API_BASE_URL 改为生产地址
#
# 编译时通过 --dart-define-from-file=.dev.env|.prod.env 注入。
# .dev.env / .prod.env 已被 .gitignore，不会提交，请勿把真实密钥写进本模板。

# Supabase 项目地址与 publishable key（认证依赖）
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Google 登录的 Web Client ID（如不使用可留空）
GOOGLE_WEB_CLIENT_ID=

# 后端 API 地址：dev 用 https://dev.echo-loop.top，prod 用 https://www.echo-loop.top
API_BASE_URL=https://dev.echo-loop.top
